{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://edushare.internal/schemas/cheatsheet/v1",
  "title": "EduShare Cheatsheet Document v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "document_type", "generated_at",
    "title", "course", "level", "metadata", "sections"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "document_type":  { "type": "string", "const": "cheatsheet" },
    "generated_at":   { "type": "string", "minLength": 10 },
    "document_hash":  { "type": "string" },
    "title":  { "type": "string", "minLength": 1 },
    "course": { "type": "string", "minLength": 1 },
    "level": {
      "type": "string",
      "enum": ["Beginner","Elementary","Intermediate","Advanced","Expert"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["purpose"],
      "properties": {
        "purpose":      { "type": "string", "minLength": 1 },
        "exam_context": { "type": "string" },
        "topics":       { "type": "array", "items": { "type": "string" } }
      }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/cheat_section" }
    }
  },
  "definitions": {
    "cheat_section": {
      "type": "object",
      "additionalProperties": false,
      "required": ["section_title","section_type","entries"],
      "properties": {
        "section_title": { "type": "string", "minLength": 1 },
        "section_type": {
          "type": "string",
          "enum": ["formulas","definitions","rules","examples","summary_table","steps"]
        },
        "entries": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/cheat_entry" }
        }
      }
    },
    "cheat_entry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label","content"],
      "properties": {
        "label":   { "type": "string", "minLength": 1 },
        "content": { "type": "string", "minLength": 1 },
        "notes":   { "type": "string" },
        "example": { "type": "string" }
      }
    }
  }
}
