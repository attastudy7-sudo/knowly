{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://edushare.internal/schemas/quiz/v1",
  "title": "EduShare Quiz Document v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "document_type", "generated_at",
    "title", "course", "level", "type",
    "metadata", "instructions", "sections"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "document_type":  { "type": "string", "const": "quiz" },
    "generated_at":   { "type": "string", "minLength": 10 },
    "document_hash":  { "type": "string", "minLength": 1 },
    "title":  { "type": "string", "minLength": 1 },
    "course": { "type": "string", "minLength": 1 },
    "level": {
      "type": "string",
      "enum": ["Beginner", "Elementary", "Intermediate", "Advanced", "Expert"]
    },
    "type": {
      "type": "string",
      "enum": ["Self-Assessment Quiz", "Likely Examination Questions"]
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "required": ["time", "total_marks", "total_questions"],
      "properties": {
        "time":            { "type": "string", "minLength": 1 },
        "total_marks":     { "type": "integer", "minimum": 1 },
        "total_questions": { "type": "integer", "minimum": 1 }
      }
    },
    "instructions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "sections": {
      "type": "array",
      "minItems": 1,
      "maxItems": 4,
      "items": { "$ref": "#/definitions/section" }
    }
  },
  "definitions": {
    "section": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "section_letter", "section_title", "question_type",
        "questions_count", "marks_per_question", "total_section_marks", "questions"
      ],
      "properties": {
        "section_letter": { "type": "string", "enum": ["A","B","C","D"] },
        "section_title":  { "type": "string", "minLength": 1 },
        "question_type": {
          "type": "string",
          "enum": ["multiple_choice","true_false","short_answer","problem_solving"]
        },
        "questions_count":      { "type": "integer", "minimum": 1 },
        "marks_per_question":   { "type": "number",  "minimum": 0 },
        "total_section_marks":  { "type": "integer", "minimum": 0 },
        "questions": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/definitions/question" }
        }
      }
    },
    "question": {
      "type": "object",
      "additionalProperties": false,
      "required": ["question_number","question_text","correct_answer","explanation","marks"],
      "properties": {
        "question_number": { "type": "integer", "minimum": 1 },
        "question_text":   { "type": "string",  "minLength": 5 },
        "correct_answer":  { "type": "string",  "minLength": 1 },
        "explanation":     { "type": "string",  "minLength": 20 },
        "marks":           { "type": "number",  "minimum": 0 },
        "options": {
          "type": "array",
          "minItems": 4,
          "maxItems": 4,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["letter","text"],
            "properties": {
              "letter": { "type": "string", "enum": ["A","B","C","D"] },
              "text":   { "type": "string", "minLength": 1 }
            }
          }
        },
        "subparts": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["label","question_text","correct_answer","explanation","marks"],
            "properties": {
              "label":         { "type": "string", "pattern": "^[a-z]\\)$" },
              "question_text": { "type": "string", "minLength": 5 },
              "correct_answer":{ "type": "string", "minLength": 1 },
              "explanation":   { "type": "string", "minLength": 20 },
              "marks":         { "type": "integer","minimum": 1 }
            }
          }
        }
      }
    }
  }
}
